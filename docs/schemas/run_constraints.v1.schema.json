{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sch_run_constraints_v1",
  "title": "Run Constraints v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "environment",
    "execution",
    "latency_targets",
    "reporting_must_include"
  ],
  "properties": {
    "version": {
      "const": "run_constraints.v1"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "cpu",
        "ram",
        "storage",
        "offline"
      ],
      "properties": {
        "os": {
          "type": "string",
          "minLength": 1
        },
        "cpu": {
          "type": "string",
          "minLength": 1
        },
        "ram": {
          "type": "string",
          "minLength": 1
        },
        "storage": {
          "type": "string",
          "minLength": 1
        },
        "offline": {
          "type": "boolean"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cold_warm",
        "concurrency",
        "timeouts",
        "output_limits"
      ],
      "properties": {
        "cold_warm": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mode",
              "description"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "cold",
                  "warm"
                ]
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "concurrency": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "threads"
          ],
          "properties": {
            "threads": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "timeouts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "per_query_sec",
            "per_repo_sec"
          ],
          "properties": {
            "per_query_sec": {
              "type": "integer",
              "minimum": 1
            },
            "per_repo_sec": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "output_limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_hits"
          ],
          "properties": {
            "max_hits": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "latency_targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "p50_ms",
        "p95_ms",
        "p99_ms"
      ],
      "properties": {
        "p50_ms": {
          "type": "integer",
          "minimum": 1
        },
        "p95_ms": {
          "type": "integer",
          "minimum": 1
        },
        "p99_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "reporting_must_include": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
