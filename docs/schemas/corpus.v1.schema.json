{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sch_corpus_v1",
  "title": "Benchmark Corpus v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "corpora"
  ],
  "properties": {
    "version": {
      "const": "corpus.v1"
    },
    "corpora": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "url",
          "commit",
          "license",
          "primary_language"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "commit": {
            "type": "string",
            "pattern": "^[a-f0-9]{7,40}$"
          },
          "tag": {
            "type": "string",
            "minLength": 1
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "primary_language": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
