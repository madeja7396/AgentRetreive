{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sch_baselines_v1",
  "title": "Benchmark Baselines v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "baselines"
  ],
  "properties": {
    "version": {
      "const": "baselines.v1"
    },
    "baselines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tool",
          "version",
          "cmd_template"
        ],
        "properties": {
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "cmd_template": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
