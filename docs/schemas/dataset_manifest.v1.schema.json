{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sch_dataset_manifest_v1",
  "title": "Dataset Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "dataset_id",
    "created_at_utc",
    "source",
    "license",
    "collection",
    "artifacts"
  ],
  "properties": {
    "version": {
      "const": "dataset_manifest.v1"
    },
    "dataset_id": {
      "type": "string",
      "pattern": "^ds_[a-z0-9_]+$"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "url",
        "snapshot"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "git_repository",
            "archive",
            "custom"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "snapshot": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "commit": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[a-f0-9]{40}$"
            },
            "tag": {
              "type": [
                "string",
                "null"
              ]
            },
            "date": {
              "type": [
                "string",
                "null"
              ],
              "format": "date"
            }
          }
        }
      }
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script",
        "script_version"
      ],
      "properties": {
        "script": {
          "type": "string",
          "minLength": 1
        },
        "script_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
