{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sch_daemon_task_v1",
  "title": "Agent Daemon Task v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "type",
    "attempts",
    "max_attempts",
    "created_at_utc",
    "payload"
  ],
  "properties": {
    "version": {
      "const": "daemon_task.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{3,64}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "contract_harness",
        "contract_harness_refresh",
        "prepare_worktree"
      ]
    },
    "attempts": {
      "type": "integer",
      "minimum": 0
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "last_started_at_utc": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_error": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
