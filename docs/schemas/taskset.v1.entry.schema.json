{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sch_taskset_v1_entry",
  "title": "Benchmark Taskset v1 Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "repo",
    "query_nl",
    "query_dsl",
    "gold"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "repo": {
      "type": "string",
      "enum": [
        "ripgrep",
        "fd",
        "fzf",
        "curl",
        "fmt"
      ]
    },
    "query_nl": {
      "type": "string",
      "minLength": 1
    },
    "query_dsl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must",
        "k"
      ],
      "properties": {
        "must": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "k": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "gold": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "file",
        "anchor"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "span"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "anchor": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
